# Stockflow environment example
# Copy to `.env.local` for local overrides (never commit secrets).

# Node server bind (used by `next start` / Docker)
PORT=3000
BIND_HOST=0.0.0.0

# Set to 1 to disable Next.js telemetry in CI/containers
NEXT_TELEMETRY_DISABLED=1

# Future: replace JSON file feeds with department HTTP APIs
# SALES_API_URL=
# INCOMING_API_URL=
# INVENTORY_API_URL=
